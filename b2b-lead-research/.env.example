# B2B Lead Research Tool - Environment Variables

# Required: Google Places API
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Optional: Google PageSpeed Insights API
GOOGLE_PAGESPEED_API_KEY=your_pagespeed_api_key_here

# Optional: Companies House API (UK only, free)
COMPANIES_HOUSE_API_KEY=your_companies_house_api_key_here

# Optional: Bing Web Search API (global discovery, 1000 tx/mo free)
BING_SEARCH_API_KEY=your_bing_search_api_key_here

# Optional: AI Copywriter (OpenAI or OpenRouter)
OPENAI_API_KEY=your_openai_api_key_here
# OR
OPENROUTER_API_KEY=your_openrouter_api_key_here
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Optional: Webhook / CRM Export
WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/...
WEBHOOK_MODE=generic
WEBHOOK_AUTH_TOKEN=
HUBSPOT_API_KEY=your_hubspot_key_here
PIPEDRIVE_API_KEY=your_pipedrive_key_here

# Optional: Telegram for report delivery
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Output settings
OUTPUT_DIR=./output
BATCH_SIZE=500